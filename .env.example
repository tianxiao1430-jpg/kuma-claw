# Kuma Claw 环境变量配置
# 复制此文件为 .env 并填入你的密钥

# ============================================
# 即时通讯平台
# ============================================

# Telegram Bot Token（从 @BotFather 获取）
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Slack（可选）
SLACK_BOT_TOKEN=xoxb-xxx-xxx-xxx
SLACK_APP_TOKEN=xapp-xxx-xxx-xxx

# ============================================
# Google 服务
# ============================================

# Google AI API Key（用于 Gemini）
GOOGLE_API_KEY=your_google_api_key

# Google OAuth（用于 Gmail/Calendar 等）
GOOGLE_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret

# ============================================
# 可选：其他 AI 模型
# ============================================

# OpenAI
# OPENAI_API_KEY=sk-xxx

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-xxx

# 自定义模型（格式：provider/model）
# KUMA_MODEL=openai/gpt-4
# KUMA_MODEL=anthropic/claude-3-5-sonnet

# ============================================
# 高级配置
# ============================================

# 日志级别（DEBUG, INFO, WARNING, ERROR）
# LOG_LEVEL=INFO

# Skills 目录（可选）
# KUMA_SKILLS_DIR=/path/to/skills

# Web UI 端口（默认 8080）
# KUMA_WEB_PORT=8080

# ============================================
# 安全配置
# ============================================

# 用户白名单（逗号分隔的 Telegram/Slack user ID）
# 为空表示允许所有人（不推荐公开部署）
# KUMA_ALLOWED_USERS=123456789,987654321

# 每用户每分钟请求限制（0 = 不限制）
# KUMA_RATE_LIMIT=20
